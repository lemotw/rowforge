{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "/tmp/**" },
        { "path": "/private/tmp/**" },
        { "path": "/Volumes/**" }
      ]
    },
    "opener:allow-open-url",
    "dialog:default",
    "dialog:allow-open"
  ]
}
